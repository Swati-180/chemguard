
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile within the ChemGuard AI system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity (matching Firebase Auth UID)."
        },
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "username": {
          "type": "string",
          "description": "Unique username for display."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "User's role in the system.",
          "enum": ["admin", "pharma", "transporter"]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the profile was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role",
        "createdAt"
      ]
    },
    "ChemicalBatch": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChemicalBatch",
      "type": "object",
      "description": "Represents a specific batch of a chemical.",
      "properties": {
        "id": { "type": "string" },
        "batchId": { "type": "string" },
        "chemicalName": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "productionDate": { "type": "string", format: "date" },
        "storageLocation": { "type": "string" },
        "status": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "batchId", "chemicalName", "quantity", "unit", "productionDate", "storageLocation", "status", "createdBy", "createdAt"]
    },
    "ChemicalInventory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChemicalInventory",
      "type": "object",
      "description": "Defines the properties of a chemical item in inventory.",
      "properties": {
        "id": { "type": "string" },
        "chemicalName": { "type": "string" },
        "batchId": { "type": "string" },
        "manufacturer": { "type": "string" },
        "quantity": { "type": "number" },
        "storageLocation": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" },
        "status": { "type": "string" }
      },
      "required": ["id", "chemicalName", "batchId", "manufacturer", "quantity", "storageLocation", "expiryDate", "status"]
    },
    "ShipmentRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ShipmentRequest",
      "type": "object",
      "description": "Manages chemical shipment requests.",
      "properties": {
        "id": { "type": "string" },
        "shipmentId": { "type": "string" },
        "batchId": { "type": "string" },
        "destination": { "type": "string" },
        "transporter": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "shipmentId", "batchId", "destination", "transporter", "status", "createdAt"]
    },
    "UsageLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UsageLog",
      "type": "object",
      "description": "Logs movements and consumption of chemicals.",
      "properties": {
        "id": { "type": "string" },
        "chemicalName": { "type": "string" },
        "batchId": { "type": "string" },
        "quantityUsed": { "type": "string" },
        "purpose": { "type": "string" },
        "technician": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chemicalName", "batchId", "quantityUsed", "purpose", "technician", "date"]
    },
    "Alert": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Alert",
      "type": "object",
      "description": "Stores system alerts.",
      "properties": {
        "id": { "type": "string" },
        "alertIdentifier": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "alertType": { "type": "string" },
        "severity": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["id", "alertIdentifier", "timestamp", "alertType", "severity", "status", "description"]
    },
    "HardwareDevice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HardwareDevice",
      "type": "object",
      "description": "Represents an IoT device monitored by the system.",
      "properties": {
        "id": { "type": "string" },
        "deviceId": { "type": "string" },
        "deviceType": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string" },
        "lastSignal": { "type": "string", "format": "date-time" },
        "alertStatus": { "type": "string" }
      },
      "required": ["id", "deviceId", "deviceType", "location", "status", "lastSignal", "alertStatus"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profiles. Accessible by owner or admins."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "RoleAdmin",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Admin role existence check."
        }
      },
      {
        "path": "/roles_pharma/{userId}",
        "definition": {
          "entityName": "RolePharma",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Pharma role existence check."
        }
      },
      {
        "path": "/roles_transporter/{userId}",
        "definition": {
          "entityName": "RoleTransporter",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Transporter role existence check."
        }
      },
      {
        "path": "/chemical_inventory/{id}",
        "definition": { "entityName": "ChemicalInventory", "schema": { "$ref": "#/backend/entities/ChemicalInventory" }, "description": "Inventory master list." }
      },
      {
        "path": "/chemical_batches/{id}",
        "definition": { "entityName": "ChemicalBatch", "schema": { "$ref": "#/backend/entities/ChemicalBatch" }, "description": "Specific batches." }
      },
      {
        "path": "/shipment_requests/{id}",
        "definition": { "entityName": "ShipmentRequest", "schema": { "$ref": "#/backend/entities/ShipmentRequest" }, "description": "Shipment requests." }
      },
      {
        "path": "/usage_logs/{id}",
        "definition": { "entityName": "UsageLog", "schema": { "$ref": "#/backend/entities/UsageLog" }, "description": "Activity logs." }
      },
      {
        "path": "/alerts/{id}",
        "definition": { "entityName": "Alert", "schema": { "$ref": "#/backend/entities/Alert" }, "description": "System alerts." }
      },
      {
        "path": "/hardware_devices/{id}",
        "definition": { "entityName": "HardwareDevice", "schema": { "$ref": "#/backend/entities/HardwareDevice" }, "description": "Monitored hardware devices." }
      }
    ]
  }
}
