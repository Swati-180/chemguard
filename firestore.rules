rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return request.auth != null ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : null;
    }

    function isStaff() {
      // Expanded to include all demo and production roles for cross-portal visibility
      return isSignedIn() && getUserData() != null && 
             getUserData().role in ['admin', 'pharma', 'transporter', 'Admin', 'Dispatcher', 'Monitor'];
    }

    function isAdmin() {
      return isSignedIn() && getUserData() != null && (getUserData().role == 'admin' || getUserData().role == 'Admin');
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin() && resource != null;
      
      function isOwner(uid) {
        return isSignedIn() && request.auth.uid == uid;
      }
    }

    match /drivers/{driverId} {
      allow get, list: if isStaff();
      allow write: if isAdmin();
    }

    match /vehicles/{vehicleId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }

    match /shipments/{shipmentId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }
    
    match /shipment_requests/{requestId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }

    match /locations/{locationId} {
      allow get, list: if isStaff();
      allow write: if isAdmin();
    }

    match /chemical_batches/{batchId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }
    
    match /chemical_inventory/{invId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }

    match /iot_devices/{deviceId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }
    
    match /hardware_devices/{deviceId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }

    match /sensor_alerts/{alertId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }

    match /transport_alerts/{alertId} {
      allow get, list: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }
    
    match /alerts/{alertId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }

    match /compliance_records/{recordId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }
    
    match /compliance_logs/{logId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }
    
    match /usage_logs/{logId} {
      allow get, list: if isStaff();
      allow write: if isStaff();
    }
  }
}