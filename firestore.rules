
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isPharma() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_pharma/$(request.auth.uid));
    }

    function isTransporter() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_transporter/$(request.auth.uid));
    }

    function hasAnyRole() {
      return isAdmin() || isPharma() || isTransporter();
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /roles_pharma/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /roles_transporter/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /chemical_inventory/{id} {
      allow get, list: if hasAnyRole();
      allow write: if isAdmin() || isPharma();
    }

    match /chemical_batches/{id} {
      allow get, list: if hasAnyRole();
      allow write: if isAdmin() || isPharma();
    }

    match /shipment_requests/{id} {
      allow get, list: if hasAnyRole();
      allow write: if isAdmin() || isPharma() || isTransporter();
    }

    match /usage_logs/{id} {
      allow get, list: if hasAnyRole();
      allow create: if isAdmin() || isPharma();
    }

    match /alerts/{id} {
      allow get, list: if hasAnyRole();
      allow write: if isAdmin() || isPharma() || isTransporter();
    }
  }
}
