
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to fetch user data for role checks
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isPharma() {
      return isSignedIn() && (getUserData().role == 'pharma' || isAdmin());
    }

    function isTransporter() {
      return isSignedIn() && (getUserData().role == 'transporter' || isAdmin());
    }

    function hasAnyRole() {
      return isSignedIn() && (getUserData().role in ['admin', 'pharma', 'transporter']);
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // Legacy role check collections (kept for compatibility with existing code)
    match /roles_admin/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }
    match /roles_pharma/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }
    match /roles_transporter/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /chemical_inventory/{id} {
      allow get, list: if hasAnyRole();
      allow write: if isPharma();
    }

    match /chemical_batches/{id} {
      allow get, list: if hasAnyRole();
      allow write: if isPharma();
    }

    match /shipment_requests/{id} {
      allow get, list: if hasAnyRole();
      allow write: if isPharma() || isTransporter();
    }

    match /usage_logs/{id} {
      allow get, list: if hasAnyRole();
      allow create: if isPharma();
    }

    match /alerts/{id} {
      allow get, list: if hasAnyRole();
      allow write: if isPharma() || isTransporter();
    }

    match /hardware_devices/{id} {
      allow get, list: if hasAnyRole();
      allow write: if isAdmin();
    }

    match /compliance_logs/{id} {
      allow get, list: if hasAnyRole();
      allow create: if isPharma();
    }
  }
}
